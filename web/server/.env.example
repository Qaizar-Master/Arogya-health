# Arogya — Server Environment Variables
# Copy this to .env and fill in your values

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/arogyadb

# ── JWT Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-minimum-32-chars
JWT_REFRESH_SECRET=change-me-to-another-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ── Anthropic AI ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Email (Nodemailer) ────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=Arogya <noreply@arogya.health>

# ── File Storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ── Rate Limiting ─────────────────────────────────────────────────────────────
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=20
